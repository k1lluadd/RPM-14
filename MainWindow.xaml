<Window x:Class="RPM_14.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Стили WPF. Гаврилов Артём.ИС24." Height="511" Width="550"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Лабораторная работа №14" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Стили WPF" FontSize="16" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <TextBlock Text="Примеры из теоретической части:" FontWeight="Bold" Margin="0,0,0,10"/>
        <Button Content="Пример 1: Без стилей (ручная настройка)" Click="BtnExample1_Click" 
                Margin="0,5" Padding="10,5"/>
        <Button Content="Пример 2: Стиль для всех кнопок" Click="BtnExample2_Click" 
                Margin="0,5" Padding="10,5"/>
        <Button Content="Пример 3: Стиль с ключом" Click="BtnExample3_Click" 
                Margin="0,5" Padding="10,5"/>
        <Button Content="Пример 4: Иерархические стили" Click="BtnExample4_Click" 
                Margin="0,5" Padding="10,5"/>
        <Button Content="Пример 5: EventSetter" Click="BtnExample5_Click" 
                Margin="0,5" Padding="10,5"/>

        <Separator Margin="0,20"/>

        <TextBlock Text="Практическое задание:" FontWeight="Bold" Margin="0,10,0,10"/>
        <Button Content="ЗАДАНИЕ 1: Калькулятор" Click="BtnTask1_Click" 
                Margin="0,5" Padding="10,5" FontSize="14"/>
    </StackPanel>
</Window>