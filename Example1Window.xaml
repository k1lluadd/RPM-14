<Window x:Class="RPM_14.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пример 1: Без стилей (Ручная настройка)" Height="160" Width="500"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">
        <TextBlock Text="Пример 1: Одинаковые атрибуты прописаны вручную у каждой кнопки." 
                   Margin="0,0,0,10" FontStyle="Italic"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Открыть" Background="DarkBlue" Foreground="White" 
                    FontFamily="Verdana" Padding="5" Margin="5"/>
            <Button Content="Обработать" Background="DarkBlue" Foreground="White" 
                    FontFamily="Verdana" Padding="5" Margin="5"/>
            <Button Content="Сохранить" Background="DarkBlue" Foreground="White" 
                    FontFamily="Verdana" Padding="5" Margin="5"/>
            <Button Content="Закрыть" Padding="5" Margin="5"/>
        </StackPanel>
    </StackPanel>
</Window>