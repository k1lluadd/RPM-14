<Window x:Class="RPM_14.Example5Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пример 5: EventSetter" Height="160" Width="500"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Margin" Value="5" />
                <EventSetter Event="Click" Handler="Button_Click"/>
            </Style.Setters>
        </Style>
    </Window.Resources>
    <StackPanel Margin="10">
        <TextBlock Text="Пример 5: Все кнопки используют один обработчик события Click" 
                   Margin="0,0,0,10" FontStyle="Italic"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Открыть"/>
            <Button Content="Обработать"/>
            <Button Content="Сохранить"/>
        </StackPanel>
    </StackPanel>
</Window>